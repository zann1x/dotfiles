# Make sure to always use gpg2
alias gpg=gpg2

# One neovim to rule them all
alias nvim=nvim-linux-x86_64.appimage
alias vim=nvim

# Save typing when interacting with the dotfile manager
alias cz=chezmoi

# Windows terminal's SSH together with the tmux 3.5a installation provided by
# Debian breaks more often than not and spits out random characters on startup.
# To fix that, we use a custom version.
alias tmux=tmux-3.6b-linux-x86_64
